generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  RESPONSAVEL
  ADMIN
}

enum ChildLevel {
  INICIANTE
  BASICO
  INTERMEDIARIO
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PENDING
  EXPIRED
  CANCELED
}

enum BenefitType {
  SOCIOEDUCATIVA
  MERITO_BIMESTRAL
  PROVA_DESAFIO
  MODO_GRATUITO
}

enum BenefitStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LessonType {
  VOCABULARY
  LISTENING
  SPEAKING
  READING
  CHAT
  PRONUNCIATION
  STORY
  REVIEW
}

enum ConversationMode {
  TEXT
  VOICE
}

model User {
  id                   String   @id @default(cuid())
  name                 String
  email                String   @unique
  phone                String?
  cpf                  String?  @unique
  passwordHash         String
  role                 UserRole @default(RESPONSAVEL)
  acceptedTerms        Boolean  @default(false)
  acceptedPrivacy      Boolean  @default(false)
  confirmedResponsible Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  children        Child[]
  subscriptions   Subscription[]
  benefitRequests BenefitRequest[]
  documents       Document[]
}

model Child {
  id             String     @id @default(cuid())
  userId         String
  name           String
  age            Int
  schoolYear     String
  targetLanguage String
  level          ChildLevel @default(INICIANTE)
  goal           String?
  avatar         String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions   Subscription[]
  benefitRequests BenefitRequest[]
  documents       Document[]
  progress        Progress[]
  conversations   AiConversation[]
  achievements    Achievement[]
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  price       Decimal  @default(0)
  description String?
  limitsJson  Json?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  childId            String
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  benefitType        BenefitType        @default(MODO_GRATUITO)
  discountPercentage Int                @default(0)
  startsAt           DateTime           @default(now())
  endsAt             DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)
  plan  Plan  @relation(fields: [planId], references: [id])
}

model BenefitRequest {
  id                 String        @id @default(cuid())
  userId             String
  childId            String
  type               BenefitType
  status             BenefitStatus @default(PENDING)
  declaredIncome     Decimal?
  schoolAverage      Decimal?
  challengeGrade     Decimal?
  discountPercentage Int           @default(0)
  adminNotes         String?
  submittedAt        DateTime      @default(now())
  reviewedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  child     Child      @relation(fields: [childId], references: [id], onDelete: Cascade)
  documents Document[]
}

model Document {
  id               String         @id @default(cuid())
  benefitRequestId String?
  userId           String
  childId          String?
  fileUrl          String
  fileType         String?
  documentType     String
  status           DocumentStatus @default(PENDING)
  uploadedAt       DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  benefitRequest BenefitRequest? @relation(fields: [benefitRequestId], references: [id], onDelete: SetNull)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  child          Child?          @relation(fields: [childId], references: [id], onDelete: SetNull)
}

model Lesson {
  id          String     @id @default(cuid())
  title       String
  description String?
  language    String
  level       ChildLevel @default(INICIANTE)
  type        LessonType
  contentJson Json?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  progress Progress[]
}

model Progress {
  id          String    @id @default(cuid())
  childId     String
  lessonId    String
  score       Int       @default(0)
  completed   Boolean   @default(false)
  stars       Int       @default(0)
  attempts    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  child  Child  @relation(fields: [childId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([childId, lessonId])
}

model AiConversation {
  id          String           @id @default(cuid())
  childId     String
  mode        ConversationMode @default(TEXT)
  userMessage String
  aiResponse  String
  language    String
  level       ChildLevel       @default(INICIANTE)
  audioUrl    String?
  createdAt   DateTime         @default(now())

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String   @id @default(cuid())
  childId     String
  title       String
  description String?
  icon        String?
  earnedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)
}
